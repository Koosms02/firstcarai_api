generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Car {
  id                 String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  make               String
  model              String
  year               Int?
  price              Decimal?            @db.Decimal
  mileage            Int?
  fuelType           String?             @map("fuel_type")
  transmission       String?
  scrapedSource      String?             @map("scraped_source")
  createdAt          DateTime?           @default(now()) @map("created_at") @db.Timestamp(6)
  insuranceEstimates InsuranceEstimate[]
  recommendations    Recommendation[]

  @@map("cars")
}

model User {
  id              String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email           String           @unique
  netSalary       Decimal?         @map("net_salary") @db.Decimal
  creditScore     Int?             @map("credit_score")
  yearsLicensed   Int?             @map("years_licensed")
  gender          String?
  location        String?
  createdAt       DateTime?        @default(now()) @map("created_at") @db.Timestamp(6)
  recommendations Recommendation[]
  preferences     UserPreference[]

  @@map("users")
}

model Recommendation {
  id                   String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId               String?   @map("user_id") @db.Uuid
  carId                String?   @map("car_id") @db.Uuid
  estimatedMonthlyCost Decimal?  @map("estimated_monthly_cost") @db.Decimal
  insuranceCost        Decimal?  @map("insurance_cost") @db.Decimal
  loanCost             Decimal?  @map("loan_cost") @db.Decimal
  maintenanceCost      Decimal?  @map("maintenance_cost") @db.Decimal
  fuelCost             Decimal?  @map("fuel_cost") @db.Decimal
  score                Decimal?  @db.Decimal
  createdAt            DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  car                  Car?      @relation(fields: [carId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                 User?     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("recommendations")
}

model InsuranceEstimate {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  carId            String?   @map("car_id") @db.Uuid
  location         String?
  riskCategory     String?   @map("risk_category")
  estimatedMonthly Decimal?  @map("estimated_monthly") @db.Decimal
  createdAt        DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  car              Car?      @relation(fields: [carId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("insurance_estimates")
}

model UserPreference {
  id             String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId         String?   @map("user_id") @db.Uuid
  preferredBrand String?   @map("preferred_brand")
  carType        String?   @map("car_type")
  fuelType       String?   @map("fuel_type")
  transmission   String?
  createdAt      DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  user           User?     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@map("user_preferences")
}

model ScrapingJob {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  source       String?
  recordsAdded Int?      @map("records_added")
  status       String?
  startedAt    DateTime? @map("started_at") @db.Timestamp(6)
  completedAt  DateTime? @map("completed_at") @db.Timestamp(6)

  @@map("scraping_jobs")
}
